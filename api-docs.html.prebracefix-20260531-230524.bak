    </div>

    <div class="empty-state" id="emptyState">No hay módulos que coincidan con tu búsqueda.</div>
  </div>
</main>

<site-footer base="./"></site-footer>

<script>
/* Copy for LLMs */
function copyForLLM(){
  const btn=document.getElementById('llmBtn');
  const modules=[...document.querySelectorAll('.mod-card[data-search]')].map(c=>{
    const name=c.querySelector('.mod-name').textContent.trim();
    const desc=c.querySelector('.mod-desc')?.textContent.trim()||'';
    const url=c.querySelector('.mod-action')?.href||'';
    return `## ${name}\n${desc}\nSwagger: ${url}`;
  }).join('\n\n');

  const text=`# YiQi ERP — API Docs
OpenAPI · REST · v2.5
URL: https://apidoc.yiqi.com.ar

## Autenticación
Obtén el token desde el módulo Seguridad. Envíalo como Bearer en el header Authorization para el resto de los módulos. No hay refresh token — cuando expira se debe volver a autenticar con /token.

## Patrón de endpoints por entidad
GET /entidad/search — Búsqueda filtrada, hasta 50 registros por request.
GET /entidad/{id} — Detalle de instancia puntual.
POST /entidad — Alta. Body incluye schemaid + objeto data.
PUT /entidad/{id} — Actualización de instancia existente.
DELETE /entidad/{id} — Baja lógica/física según reglas de negocio.
GET /entidad/smartie — Vista paginada armada por usuarios.
POST /entidad/changestate — Cambio de estado de workflow.
GET|PUT /entidad/file — Descarga/carga de archivos asociados.
GET /entidad/report — Descarga de reportes predefinidos (PDFs).

## Módulos disponibles
${modules}

## Catálogo machine-readable
https://apidoc.yiqi.com.ar/modules.json`;

  navigator.clipboard.writeText(text).then(()=>{
    showSuccess();
  }).catch(()=>{
    // Fallback: descarga como .txt
    const blob=new Blob([text],{type:'text/plain'});
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download='yiqi-api-docs-llm.txt';
    a.click();
    showSuccess('Descargado');
  });
}


/* Info box toggle */
function toggleInfo(){
  document.getElementById('infoBox').classList.toggle('open');
}

/* Card toggle */
function toggleCard(card){
  card.classList.toggle('open');
}

/* Toggle all */
let allExpanded=false;
function toggleAll(){
  const cards=document.querySelectorAll('.mod-card[data-search]');
  allExpanded=!allExpanded;
  cards.forEach(c=>{ if(allExpanded) c.classList.add('open'); else c.classList.remove('open'); });
  document.getElementById('toggleAllBtn').textContent=allExpanded?'Colapsar todos':'Expandir todos';
}

/* Search */
function filterCards(q){
  const term=q.toLowerCase().trim();
  const cards=document.querySelectorAll('.mod-card[data-search]');
  let visible=0;
  cards.forEach(c=>{
    const match=!term||c.dataset.search.includes(term)||c.querySelector('.mod-name').textContent.toLowerCase().includes(term);
    c.style.display=match?'':'none';
    if(match) visible++;
  });
  document.getElementById('countBadge').textContent=visible+(visible===1?' módulo':' módulos');
  document.getElementById('emptyState').classList.toggle('show',visible===0);
}
</script>
<script src="./components/meta-pixel-events.js" defer></script>
</body>
</html>
